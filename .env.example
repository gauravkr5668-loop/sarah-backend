# ── Sarah — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Port Railway binds to (Railway sets this automatically — do not change)
PORT=5000

# Full HTTPS URL of your Make.com custom webhook scenario
# Leave blank to disable Make.com forwarding during local development
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/YOUR_WEBHOOK_ID_HERE

# Optional bearer token for basic webhook security.
# Set the same value in Vapi's webhook configuration under "Authorization".
# Leave blank to disable auth checking (not recommended in production).
SECRET_TOKEN=change_me_to_a_long_random_string

# Path to the SQLite database file.
# Railway ephemeral filesystem: use /tmp/veronica.db or attach a volume.
DATABASE_PATH=veronica.db

# Python log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
